{
  "name": "scribe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Scribe text/image inputs onto an AcroForm PDF via an LLM agent that calls field-setting tools.",
  "scripts": {
    "scribe": "tsx src/cli.ts",
    "serve": "tsx src/server.ts",
    "proof:e2e": "tsx src/proofs/end-to-end.ts",
    "proof:live": "tsx proofs/live/run-live.ts",
    "format": "biome format --write src",
    "lint": "biome check src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "openai": "^4.77.0",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
